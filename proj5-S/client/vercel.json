{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --force",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://mealgo-production.up.railway.app/api/$1"
    },
    {
      "source": "/auth/(.*)",
      "destination": "https://mealgo-production.up.railway.app/auth/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
